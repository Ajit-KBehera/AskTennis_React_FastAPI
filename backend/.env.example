# AskTennis Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Google API Key for Gemini LLM
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# Environment Settings
# =============================================================================
# Set to 'production' for deployed environments, 'development' for local dev
ENVIRONMENT=development

# =============================================================================
# CORS Configuration (Production only)
# =============================================================================
# Comma-separated list of allowed origins for production
# Example: https://asktennis.com,https://www.asktennis.com
ALLOWED_ORIGINS=

# =============================================================================
# Rate Limiting
# =============================================================================
# General API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# AI Query endpoint rate limit (requests per minute) - more restrictive
QUERY_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# Database Configuration
# =============================================================================
# Database type: 'sqlite' (default), 'duckdb', or 'cloudsql' (auto-detected if vars present)
# DB_TYPE=duckdb
# DB_PATH=duckdb:///tennis_data_with_mcp.db

# For Cloud SQL, set the following:
# INSTANCE_CONNECTION_NAME=project:region:instance
# DB_NAME=asktennis
# DB_USER=user
# DB_PASSWORD=password

# =============================================================================
# LangGraph Conversation Memory
# =============================================================================
# Checkpointer for multi-turn context memory:
# - sqlite (default): persistent across restarts
# - memory: in-process only (lost on restart)
LANGGRAPH_CHECKPOINTER=sqlite
#
# Optional: override SQLite checkpoint DB connection string
# Example: sqlite:////absolute/path/to/langgraph_checkpoints.sqlite
# LANGGRAPH_CHECKPOINT_DB=sqlite:////tmp/langgraph_checkpoints.sqlite

# =============================================================================
# Authentication
# =============================================================================
# Secret key for API authentication (X-API-Key header)
# Defaults to 'dev-key' in development if not set
API_SECRET_KEY=your_secret_api_key_here
