# AskTennis Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Google API Key for Gemini LLM
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# Environment Settings
# =============================================================================
# Set to 'production' for deployed environments, 'development' for local dev
ENVIRONMENT=development

# =============================================================================
# CORS Configuration (Production only)
# =============================================================================
# Comma-separated list of allowed origins for production
# Example: https://asktennis.com,https://www.asktennis.com
ALLOWED_ORIGINS=

# =============================================================================
# Rate Limiting
# =============================================================================
# General API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# AI Query endpoint rate limit (requests per minute) - more restrictive
QUERY_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# Database Configuration
# =============================================================================
# Auto-detects based on variables. Defaults to SQLite if strictly local.
# DB_FILE_NAME="tennis_data_with_mcp.db"
# AUTH_DB_FILE_NAME="asktennis_auth.db"

# -----------------------------------------------------------------------------
# Tennis Database (Main Data)
# -----------------------------------------------------------------------------
# TENNIS_DB_NAME=tennis_data_with_mcp
# TENNIS_DB_USER=your_tennis_user
# TENNIS_DB_PASSWORD=your_tennis_password
# INSTANCE_CONNECTION_NAME=project:region:instance (Required for Cloud SQL)

# -----------------------------------------------------------------------------
# Auth Database (Users, History)
# -----------------------------------------------------------------------------
# AUTH_DB_NAME=asktennis_auth
# AUTH_DB_USER=your_auth_user
# AUTH_DB_PASSWORD=your_auth_password

# -----------------------------------------------------------------------------
# Legacy / Shared Config (Optional Fallback)
# -----------------------------------------------------------------------------
# DB_NAME=tennis_data_with_mcp
# DB_USER=user
# DB_PASSWORD=password

# =============================================================================
# LangGraph Conversation Memory
# =============================================================================
# Checkpointer for multi-turn context memory:
# - sqlite (default): persistent across restarts
# - memory: in-process only (lost on restart)
LANGGRAPH_CHECKPOINTER=sqlite
#
# Optional: override SQLite checkpoint DB connection string
# Example: sqlite:////absolute/path/to/langgraph_checkpoints.sqlite
# LANGGRAPH_CHECKPOINT_DB=sqlite:////tmp/langgraph_checkpoints.sqlite

# =============================================================================
# Authentication
# =============================================================================
# JWT Secret Key is required for session security. 
# Generate one using: openssl rand -hex 32
# JWT_SECRET_KEY=your_jwt_secret_here
